# Dependencies
node_modules/

# Secrets & environment (NEVER commit — contains DB password, session secret, API keys)
.env
.env.*
!.env.example

# Build output
dist/
dist-ssr/
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local Claude Code tooling (machine-specific launch config)
.claude/

# Capacitor — generated native iOS artifacts (the ios/ project is created on a Mac
# with `npx cap add ios`; these bits are build output, not source)
/ios/App/App/public/
/ios/App/Pods/
/ios/App/build/
/ios/DerivedData/
*.xcworkspace/xcuserdata/
*.xcuserstate

