# PostgreSQL connection string (required — the app throws on boot without it)
DATABASE_URL=postgresql://user:password@localhost:5432/robotat
PORT=5000

# Session signing secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# --- Assessment delivery: email (optional; logs to console if unset) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=robotat@nasl-tech.com
# SMTP_PASS=
# ASSESSMENT_INBOX=assessments@nasl-tech.com

# --- Assessment delivery: WhatsApp ---
# Business number for the wa.me click-to-chat link (digits, incl. country code)
WHATSAPP_BUSINESS_NUMBER=966500000000
# Optional WhatsApp Cloud API push (from Meta) — click-to-chat works without these
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=

# --- Native iOS app (Capacitor) ---
# Build-time only (baked into the client bundle, so it must start with VITE_).
# Absolute HTTPS origin of the deployed backend the native app should call. Leave
# UNSET for web/dev builds (the client uses same-origin relative /api paths).
# VITE_API_URL=https://robotat.nasl-tech.com

# Server-side: absolute origin used to build emailed links (reset/verify). Falls
# back to the request's own origin when unset.
# PUBLIC_APP_URL=https://robotat.nasl-tech.com
